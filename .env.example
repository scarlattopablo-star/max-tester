# Copiá este archivo como ".env" y completá la clave del proveedor que elijas.

# ── CEREBRO IA ──────────────────────────────────────────────
# Proveedor: gemini (gratis) | groq (gratis) | openai (pago) | claude (pago)
IA_PROVIDER=gemini

# GEMINI (gratis, solo tu Gmail): la clave se saca en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Otras claves (solo si cambiás IA_PROVIDER):
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# (Opcional) Forzar un modelo puntual; si se deja vacío usa el por defecto del proveedor.
IA_MODEL=

# ── MERCADO PAGO (link de pago que genera Max) ──────────────
# Access Token de PRODUCCIÓN de la cuenta MP del negocio (empieza con APP_USR-...).
# Se saca en https://www.mercadopago.com.uy/developers -> Tus integraciones -> Credenciales.
MP_ACCESS_TOKEN=

# ── SYNC AUTOMÁTICO CON LA API DE MERCADO LIBRE ─────────────
# App ID y Secret Key de una aplicación creada en developers.mercadolibre.com.uy
# (Tus integraciones -> Crear aplicación; redirect: la URL pública del bot; scope read).
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# URL pública del bot (para armar links). Ej: https://max-tester.onrender.com
APP_URL=

# Número del chip DEDICADO del bot (NO el 091 629 784). Solo informativo.
NUMERO_BOT=

# Aviso de ventas web (endpoint /api/notificar-venta)
NOTIFY_TOKEN=
NUMERO_AVISOS=091629784
# Sesion de WhatsApp en Neon (la misma DB del sitio web)
DATABASE_URL=
# Encender WhatsApp en este proceso (1 = si). Sin esto solo corre el server web.
WHATSAPP_ON=
